tentativas = 0

while tentativas < 3:
    usuario = input("Digite o usuário: ")
    senha = input("Digite a senha: ")

    tentativas += 1

    if usuario == "aluno" and senha == "12345":
      print("Acesso liberado")
      break
    else:
      if tentativas < 3:
        print("Tente novamente")
      else:
        print("Você tentou 3 vezes :/")
